# ── Application ─────────────────────────────────
APP_NAME=AI Support Agent Backend
APP_VERSION=0.1.0
DEBUG=True
ENVIRONMENT=development

# ── API ─────────────────────────────────────────
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["*"]

# Docker API runtime tuning
# Keep false for stable local container networking; set true only when you need hot reload.
API_RELOAD=false
# Used when API_RELOAD=false.
API_WORKERS=2

# ── Database ────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/support_db
DB_ECHO=False
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ── Redis ───────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_TOKEN_BLACKLIST_DB=1

# ── JWT ─────────────────────────────────────────
JWT_SECRET_KEY=CHANGE-ME-IN-PRODUCTION
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Celery ──────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/3

# ── Gmail OAuth2 ────────────────────────────────
GMAIL_CLIENT_ID=your-google-client-id
GMAIL_CLIENT_SECRET=your-google-client-secret
GMAIL_REDIRECT_URI=http://localhost:8000/api/v1/gmail/callback
GMAIL_POLL_INTERVAL_SECONDS=60

# ── Logging ─────────────────────────────────────
LOG_LEVEL=INFO

# ── RAG Embeddings ───────────────────────────────
# Local/default embedding model (sentence-transformers)
RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Toggle Gemini embeddings on/off (like USE_REALTIME)
# False -> use sentence-transformers (local)
# True  -> use Gemini embedding API
USE_GEMINI_EMBEDDINGS=False

# Gemini embedding settings (used only when USE_GEMINI_EMBEDDINGS=True)
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview
GEMINI_TRANSCRIPTION_MODEL=gemini-2.5-flash
GEMINI_TRANSCRIPTION_INLINE_MAX_BYTES=14680064
GEMINI_IMAGE_ANALYSIS_MODEL=gemini-2.5-flash

# Keep this at 384 to match the current pgvector column dimension in this project.
GEMINI_EMBEDDING_DIMENSION=384
GEMINI_EMBEDDING_QUERY_TASK_TYPE=RETRIEVAL_QUERY
GEMINI_EMBEDDING_DOCUMENT_TASK_TYPE=RETRIEVAL_DOCUMENT

# ── WhatsApp ────────────────────────────────────
# Provider: "meta" (official Cloud API) or "bridge" (unofficial whatsapp-web.js bridge)
WHATSAPP_PROVIDER=meta

# ── Visual AI Screenshare ───────────────────────
# If true, screenshare assistance embeds sampled frames with Gemini embeddings.
# If false, it uses the currently selected visual provider embedding backend.
VISUAL_SCREENSHARE_USE_GEMINI_EMBEDDINGS=False
VISUAL_SCREENSHARE_GEMINI_MODEL=gemini-embedding-2-preview
VISUAL_SCREENSHARE_EMBEDDING_DIMENSION=512

# Screenshare ingest settings (client can still override per request)
VISUAL_SCREENSHARE_TARGET_FPS=1.0
VISUAL_SCREENSHARE_MAX_FRAMES=120
VISUAL_SCREENSHARE_MAX_VIDEO_MB=50
VISUAL_SCREENSHARE_MAX_VIDEO_DURATION_SECONDS=300
VISUAL_SCREENSHARE_FFMPEG_BIN=ffmpeg
VISUAL_SCREENSHARE_FFPROBE_BIN=ffprobe

# Meta Cloud API settings (when WHATSAPP_PROVIDER=meta)
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-meta-access-token
WHATSAPP_VERIFY_TOKEN=my-whatsapp-verify-token
WHATSAPP_API_VERSION=v21.0

# Web bridge settings (when WHATSAPP_PROVIDER=bridge)
WHATSAPP_BRIDGE_URL=http://localhost:3000
WHATSAPP_BRIDGE_API_KEY=
