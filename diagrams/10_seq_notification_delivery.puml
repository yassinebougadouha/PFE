@startuml
autonumber
skinparam shadowing false
title Sequence - Notification Delivery and Read Acknowledgement

participant "Conversation/Ticket Events" as Events
participant "NotificationService" as NS
database "PostgreSQL" as DB
participant "Notifications API" as API
participant "Frontend" as FE
actor "Agent/Admin" as User

Events -> NS : trigger_notification(event_type, target_users)
NS -> DB : Insert notifications(action_url, payload)

User -> FE : Open notifications panel
FE -> API : GET /api/v1/notifications
API -> DB : Query unread + recent notifications
API --> FE : notifications list
FE --> User : Display badges + links

User -> FE : Mark notification as read
FE -> API : POST/PATCH mark-as-read
API -> DB : Update is_read=true
API --> FE : success

@enduml
