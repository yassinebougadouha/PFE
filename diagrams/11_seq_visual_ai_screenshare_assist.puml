@startuml
autonumber
skinparam shadowing false
title Sequence - Visual AI Screenshare Assist

actor Client
participant "Frontend (voice/call page)" as FE
participant "Visual AI Route" as Route
participant "VisualAIService" as VisualSvc
participant "OCR/UI Analyzer" as OCR
participant "Embedding/Similarity" as Embed
participant "PostgreSQL" as DB

Client -> FE : Share screen frame/video chunk
FE -> Route : POST /api/v1/visual-ai/screenshare/assist
Route -> VisualSvc : analyze_screenshare_frames(payload)

par frame understanding
  VisualSvc -> OCR : extract text + UI elements
  OCR --> VisualSvc : labels + hints
else retrieval context
  VisualSvc -> Embed : build/query embeddings
  Embed --> VisualSvc : nearest troubleshooting matches
end

VisualSvc -> VisualSvc : synthesize guidance and confidence
VisualSvc -> DB : Persist analysis summary (optional)
VisualSvc --> Route : assist result + recommendations
Route --> FE : 200 guidance payload
FE --> Client : Show real-time troubleshooting hints

@enduml
