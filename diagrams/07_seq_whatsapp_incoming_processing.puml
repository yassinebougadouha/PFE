@startuml
autonumber
skinparam shadowing false
title Sequence - WhatsApp Incoming Message Processing

actor "WhatsApp User" as WAUser
participant "Meta WhatsApp Cloud API" as Meta
participant "WhatsApp Route" as Route
participant "WhatsAppService" as Service
queue "Celery (whatsapp queue)" as Queue
participant "Celery Worker" as Worker
database "PostgreSQL" as DB
participant "NotificationService" as NS

WAUser -> Meta : Send WhatsApp message
Meta -> Route : POST /api/v1/whatsapp/webhook
Route -> Service : validate_and_parse_webhook(payload)
Service --> Route : normalized incoming message

Route -> Queue : enqueue process_whatsapp_incoming_task
Route --> Meta : 200 OK

Queue -> Worker : process_whatsapp_incoming_task
Worker -> Service : upsert_conversation_and_message(...)
Service -> DB : Insert/Update Conversation
Service -> DB : Insert Message
Service -> DB : Link/open Ticket if required

Worker -> NS : notify_assigned_agents(conversation_id)
NS -> DB : Insert Notification rows

@enduml
