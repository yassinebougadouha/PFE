@startuml
skinparam shadowing false
title AI Support Agent Platform - Deployment Diagram

node "User Devices" {
  node "Client Browser" as ClientBrowser
  node "Agent/Admin Browser" as OperatorBrowser
  node "WhatsApp Mobile App" as WAMobile
}

node "Docker Host" {
  node "api container\nFastAPI + Uvicorn\n:8000" as API
  node "celery_worker container\nCelery worker" as Worker
  node "celery_beat container\nScheduler" as Beat
  node "flower container\nMonitoring UI\n:5555" as Flower
  node "whatsapp_bridge container\nNode.js bridge\n:3000" as Bridge
  database "postgres container\nPostgreSQL 16\n:5432" as PG
  node "redis container\nRedis 7\n:6379" as Redis
}

cloud "Google Gmail API" as GmailAPI
cloud "Meta WhatsApp Cloud API" as MetaWA

ClientBrowser --> API : HTTPS REST
OperatorBrowser --> API : HTTPS REST
OperatorBrowser --> Flower : Monitor tasks
WAMobile --> MetaWA : WhatsApp messages
MetaWA --> API : Webhooks / send

API --> PG : SQLAlchemy async
API --> Redis : cache + blacklist + broker client
API --> GmailAPI : OAuth2 + sync
API --> Bridge : HTTP bridge webhook/send

Worker --> Redis : consume queues
Worker --> PG : persist results
Worker --> GmailAPI : background sync
Worker --> MetaWA : outbound message processing

Beat --> Redis : enqueue schedules
Beat --> Worker : periodic jobs

Flower --> Redis : inspect tasks

@enduml
